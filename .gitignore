# ============================================================
# Root .gitignore — State Litigation Management System
# ============================================================

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.iml
*.swp
*.swo

# Local environment files with secrets
.env
.env.local
.env.production
.env.*.local
.env.demo

# Logs directory (local dev/test artifacts)
logs/
*.log

# Runtime attachment uploads (demo/dev — NOT committed)
attachments-data/

# Docker local override files
docker-compose.override.yml

# Temporary / scratch files
*.tmp
*.bak
*.orig


