# =========================================================
# .env.test.example — copy to .env.test on the test server
# and fill in the REQUIRED values before `docker compose up`.
# DO NOT COMMIT the real .env.test file.
# =========================================================

# ── REQUIRED ──────────────────────────────────────────────

# Postgres password (alphanumeric recommended; avoid shell-special chars)
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# JWT signing secret — MUST be base64-encoded, ≥32 bytes (HMAC-SHA256 key).
# Generate one with:   openssl rand -base64 48
SLA_JWT_SECRET=CHANGE_ME_TO_BASE64_RANDOM_SECRET

# ── OPTIONAL (safe defaults below) ────────────────────────

# Host port the frontend binds to.
# If you put Caddy/nginx/Cloudflare in front for TLS, keep this as 80
# and have the external proxy forward to it.
TEST_PORT=80

# Database name / user (defaults are fine for a fresh test install)
DB_NAME=sla_test
DB_USER=sla

# Bootstrap admin password on first start (created if SLA_BOOTSTRAP_ADMIN_ENABLED=true).
# MUST be changed after first login.
SLA_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026
