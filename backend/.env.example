# ============================================================
# backend/.env.example
# Copy to backend/.env and fill in real values before running.
# This file is safe to commit — it contains NO secrets.
# ============================================================

# PostgreSQL connection
DB_URL=jdbc:postgresql://localhost:5432/sla_demo
DB_USER=sla
DB_PASSWORD=CHANGE_ME

# JWT secret: Base64-encoded HMAC-SHA256 key (>= 32 bytes random)
# Generate: openssl rand -base64 32
SLA_JWT_SECRET=CHANGE_ME_BASE64_JWT_SECRET

# Bootstrap admin (first-time only — disable after first login in production)
SLA_BOOTSTRAP_ADMIN_ENABLED=true
SLA_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026

# Attachment storage path (absolute path or relative to working dir)
# In Docker this is mounted as a named volume at /app/attachments-data
SLA_ATTACHMENTS_BASE_DIR=./attachments-data

# Server port (default 8080)
SERVER_PORT=8080

