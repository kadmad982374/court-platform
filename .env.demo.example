# ============================================================
# .env.demo.example
# Copy to .env.demo and fill in real values before running demo deployment.
# This file is SAFE to commit — no real secrets here.
# ============================================================

# PostgreSQL
DB_NAME=sla_demo
DB_USER=sla
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# JWT secret — generate with: openssl rand -base64 32
SLA_JWT_SECRET=CHANGE_ME_BASE64_JWT_SECRET_MIN_32_BYTES

# Bootstrap admin initial password (used on first startup only)
SLA_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026

# Port the demo is exposed on (default 80)
DEMO_PORT=80

